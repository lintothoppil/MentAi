<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Registration - MentorAI</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header class="header">
        <div class="container">
            <h1 class="logo">MENTOR-AI</h1>
            <p class="tagline">AI-Powered Academic Mentoring & Support</p>
        </div>
    </header>

    <div class="container">
        <div class="card">
            <h2 class="page-title">Student Registration</h2>
            <p class="page-subtitle">Please fill in your basic details. You will complete your full profile after
                registration.</p>

            <% if (error) { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
                <% } %>
                    <% if (success) { %>
                        <div class="alert alert-success">
                            <%= success %>
                        </div>
                        <% } %>

                            <form method="POST" action="/register" class="form-container">
                                <div class="form-section">
                                    <div class="section-header">1. BASIC INFORMATION</div>
                                    <div class="table-wrapper">
                                        <table>
                                            <tr>
                                                <th>Full Name *</th>
                                                <td colspan="3"><input type="text" name="full_name" required
                                                        placeholder="Enter your full name"></td>
                                            </tr>
                                            <tr>
                                                <th>Admission Number *</th>
                                                <td colspan="3"><input type="text" name="admission_number" required
                                                        placeholder="e.g. 2023CS001"></td>
                                            </tr>
                                            <tr>
                                                <th>Email (Gmail Only) *</th>
                                                <td colspan="3"><input type="email" name="email" required
                                                        placeholder="you@gmail.com"></td>
                                            </tr>
                                            <tr>
                                                <th>Password *</th>
                                                <td colspan="3"><input type="password" name="password" required
                                                        placeholder="Minimum 6 characters"></td>
                                            </tr>
                                            <tr>
                                                <th>Confirm Password *</th>
                                                <td colspan="3"><input type="password" name="confirm_password" required
                                                        placeholder="Re-enter password"></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>

                                <div class="text-center mt-4">
                                    <input type="submit" value="Register & Complete Profile"
                                        class="btn btn-primary btn-block">
                                </div>
                            </form>

                            <div class="alert alert-info mt-4">
                                <strong>Note:</strong> After registration, you will be redirected to complete your full
                                profile with academic details, parent information, and other information.
                            </div>
                            <p class="text-center mt-4">Already have an account? <a href="/login" class="nav-link"
                                    style="display: inline-block; padding: 0.25rem 0.75rem;">Login here</a></p>
        </div>

        <footer class="footer">
            &copy; 2026 MENTOR-AI. Empowering academic excellence through intelligent mentoring.
        </footer>
    </div>
</body>

</html>