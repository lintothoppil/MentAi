<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - MentAi</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header class="header">
        <div class="container">
            <h1 class="logo">MentAi</h1>
            <p class="tagline">AI-Powered Academic Mentoring & Support</p>
        </div>
    </header>

    <div class="container">
        <div class="card" style="max-width: 500px; margin: 2rem auto;">
            <h2 class="page-title">Forgot Password</h2>
            <p class="page-subtitle">Enter your registered email to receive OTP</p>

            <% if (error) { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
                <% } %>
                    <% if (success) { %>
                        <div class="alert alert-success">
                            <%= success %>
                        </div>
                        <% } %>

                            <form method="POST" action="/forgot-password">
                                <div class="form-section">
                                    <div class="table-wrapper">
                                        <table>
                                            <tr>
                                                <th>Email Address</th>
                                                <td><input type="email" name="email" required
                                                        placeholder="your@gmail.com"></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>

                                <div class="text-center mt-4">
                                    <input type="submit" value="Send OTP" class="btn btn-primary btn-block">
                                </div>
                            </form>

                            <div class="text-center mt-4">
                                <p><a href="/login" class="nav-link"
                                        style="display: inline-block; padding: 0.25rem 0.75rem;">Back to Login</a></p>
                            </div>
        </div>

        <footer class="footer">
            &copy; 2026 MentAi. Empowering academic excellence through intelligent mentoring.
        </footer>
    </div>
</body>

</html>